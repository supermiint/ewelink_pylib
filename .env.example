# eWeLink Application Credentials (obtained from eWeLink Developer Console)
EWELINK_APP_ID=your_app_id
EWELINK_APP_SECRET=your_app_secret

# eWeLink User Login Account
EWELINK_EMAIL=your_email@example.com
EWELINK_PASSWORD=your_password

# Authentication Output (automatically written on successful login)
EWELINK_ACCESS_TOKEN=
EWELINK_REGION=as
